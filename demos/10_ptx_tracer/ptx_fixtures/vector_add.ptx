.version 8.0
.target sm_80
.address_size 64

.visible .entry vector_add(
    .param .u64 param_a,
    .param .u64 param_b,
    .param .u64 param_c,
    .param .u32 param_n
)
{
    .reg .u32   %r<5>;
    .reg .u64   %rd<8>;
    .reg .f32   %f<3>;
    .reg .pred  %p0;

    ld.param.u64    %rd0, [param_a];
    ld.param.u64    %rd1, [param_b];
    ld.param.u64    %rd2, [param_c];
    ld.param.u32    %r0,  [param_n];

    mov.u32         %r1, %tid.x;
    mov.u32         %r2, %ntid.x;
    mov.u32         %r3, %ctaid.x;
    mad.lo.u32      %r1, %r2, %r3, %r1;

    setp.ge.u32     %p0, %r1, %r0;
    @%p0 bra        $done;

    cvt.u64.u32     %rd3, %r1;
    shl.b64         %rd4, %rd3, 2;

    add.u64         %rd5, %rd0, %rd4;
    add.u64         %rd6, %rd1, %rd4;
    add.u64         %rd7, %rd2, %rd4;

    ld.global.f32   %f0, [%rd5];
    ld.global.f32   %f1, [%rd6];
    fma.rn.f32      %f2, %f0, 1.0, %f1;
    st.global.f32   [%rd7], %f2;

$done:
    ret;
}
